# ──────────────────────────────────────────────
# Google ADK / Gemini Configuration
# ──────────────────────────────────────────────
#
# This project uses Google's Agent Development Kit (ADK).
# ADK can talk to Gemini via Google AI Studio (API key)
# or via Vertex AI (GCP project + ADC).

# ── Option A: Google AI Studio (recommended for local dev) ──
# Get an API key at https://aistudio.google.com/apikey
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_GENAI_API_KEY=your-api-key-here

# ── Option B: Vertex AI ─────────────────────────────────────
# Uncomment the lines below and comment out Option A.
# You must also run: gcloud auth application-default login
#
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=8080

# ──────────────────────────────────────────────
# Firebase / Firestore
# ──────────────────────────────────────────────
# Place your service-account.json in the project root.
# It is auto-loaded by the server from ../service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
